# finESS Environment Configuration
# Copy this file to set up your local environment:
#
#   cp .env.example .env          # For Prisma (database)
#   cp .env.example .env.local    # For Next.js (runtime API keys)
#
# WHY TWO FILES?
#   - Prisma CLI reads DATABASE_URL from .env at generate/push time
#   - Next.js reads OPENROUTER_API_KEY from .env.local at runtime
#   - Both files are gitignored — your secrets stay local
#   - Do not leave DATABASE_URL empty in .env.local; it can override .env
#     and break Save/Load + Calibration routes.

# === Database (required — used by Prisma) ===
# SQLite for local development (file-based, no server needed)
DATABASE_URL=file:./dev.db

# === AI API Key (required for AI-generated graphs) ===
# Get your key at: https://openrouter.ai/keys
# The PE demo works without this key — only needed for custom queries
OPENROUTER_API_KEY=

# === AI Models (used by the in-app selector) ===
# Comma-separated: model-id|Label,model-id|Label
# JSON array is also supported: [{"id":"provider/model","label":"Model label"}]
OPENROUTER_MODELS=openrouter/auto|OpenRouter Auto
OPENROUTER_DEFAULT_MODEL=openrouter/auto

# === Aliases (legacy / fallback — do NOT set unless you know why) ===
# These names are silently honored by the code if set.
# Default-model precedence (highest first):
#   1. OPENROUTER_DEFAULT_MODEL
#   2. OPENROUTER_MODEL
#   3. first entry of OPENROUTER_MODELS
# Models-list fallback: OPENROUTER_MODELS, then AI_MODELS (same format).
# Setting OPENROUTER_MODEL while OPENROUTER_DEFAULT_MODEL is unset will
# silently change the active model — prefer OPENROUTER_DEFAULT_MODEL.
# OPENROUTER_MODEL=
# AI_MODELS=

# === Optional Live Provider Smoke ===
# Keep disabled unless a valid non-committed OPENROUTER_API_KEY is configured.
OPENROUTER_LIVE_SMOKE=0

# === Local authenticated workspace ===
# finESS creates a local HTTP-only session cookie through /api/auth/local.
# No auth secret is required for local SQLite beta mode. Shared hosted mode still
# needs a real auth provider and compliance/privacy review before deployment.
