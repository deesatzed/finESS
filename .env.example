# finESS Environment Configuration
# Copy this file to set up your local environment:
#
#   cp .env.example .env          # For Prisma (database)
#   cp .env.example .env.local    # For Next.js (runtime API keys)
#
# WHY TWO FILES?
#   - Prisma CLI reads DATABASE_URL from .env at generate/push time
#   - Next.js reads OPENROUTER_API_KEY from .env.local at runtime
#   - Both files are gitignored — your secrets stay local
#   - Do not leave DATABASE_URL empty in .env.local; it can override .env
#     and break Save/Load + Calibration routes.

# === Database (required — used by Prisma) ===
# SQLite for local development (file-based, no server needed)
DATABASE_URL=file:./dev.db

# === AI API Key (required for AI-generated graphs) ===
# Get your key at: https://openrouter.ai/keys
# The PE demo works without this key — only needed for custom queries
OPENROUTER_API_KEY=

# === AI Models (used by the in-app selector) ===
# Comma-separated: model-id|Label,model-id|Label
# JSON array is also supported: [{"id":"provider/model","label":"Model label"}]
OPENROUTER_MODELS=openrouter/auto|OpenRouter Auto
OPENROUTER_DEFAULT_MODEL=openrouter/auto

# === Aliases (legacy / fallback — do NOT set unless you know why) ===
# These names are silently honored by the code if set.
# Default-model precedence (highest first):
#   1. OPENROUTER_DEFAULT_MODEL
#   2. OPENROUTER_MODEL
#   3. first entry of OPENROUTER_MODELS
# Models-list fallback: OPENROUTER_MODELS, then AI_MODELS (same format).
# Setting OPENROUTER_MODEL while OPENROUTER_DEFAULT_MODEL is unset will
# silently change the active model — prefer OPENROUTER_DEFAULT_MODEL.
# OPENROUTER_MODEL=
# AI_MODELS=

# === Optional Live Provider Smoke ===
# Keep disabled unless a valid non-committed OPENROUTER_API_KEY is configured.
OPENROUTER_LIVE_SMOKE=0

# === AI provider call limits ===
# Per-call wall-clock timeout in ms enforced by lib/ai/openrouter-client.ts
# (and its .mjs mirror used by smoke / preflight). A misrouted reasoning model
# can run for minutes; this caps how long any single call may block. Default
# 60000.
OPENROUTER_TIMEOUT_MS=60000
# Per-call cost ceiling in USD. If a 200-OK response reports usage.cost above
# this number, the wrapper raises BUDGET_EXCEEDED and the route returns
# 402 UPSTREAM_BUDGET_EXCEEDED (the call already charged us; the caller must
# decide whether to skip downstream work). Default 0.05 ($0.05). Set to 0 to
# disable enforcement.
OPENROUTER_PER_CALL_BUDGET_USD=0.05

# === Ensemble sidecar (Forecast Mode + calibration loop) ===
# Base URL of the Python sidecar wrapping ace_hospital.UnifiedACEEnsemble.
# Defaults to http://localhost:8001 (matches docker-compose.yml). Set this
# if you run the sidecar on a different host/port. Forecast Mode (/api/forecast)
# and the calibration → Beta-prior loop (/api/calibration) require the sidecar
# to be reachable; if it's down, the API returns 502 with an actionable error.
# Boot it with: docker compose up -d ensemble
ENSEMBLE_SIDECAR_URL=http://localhost:8001

# === Path A (legacy "LLM drafts the uncertainty graph") gate ===
# Path A asks an LLM to invent a probabilistic graph from a natural-language
# prompt, then runs Monte Carlo over the LLM's hallucinated numbers. The math
# is correct; the inputs are unvalidated LLM priors. Keep "true" for local
# dev and editing flows; flip to "false" for hosted/demo deploys until the
# multi-LLM ensemble path (R6-07) lands. Must be exactly "true" or "false".
LEGACY_PATH_A_ENABLED=true

# === Local authenticated workspace ===
# finESS creates a local HTTP-only session cookie through /api/auth/local.
# No auth secret is required for local SQLite beta mode. Shared hosted mode still
# needs a real auth provider and compliance/privacy review before deployment.

# === Semantic Mode — Web search research mechanism (Phase B2) ===
# Tavily is the first search provider behind lib/search/provider.ts. The
# web-research orchestrator (lib/semantic/research/web.ts) uses this key to
# fetch snippets that the LLM then extracts distribution parameters from with
# explicit per-claim citations. Sign up at https://tavily.com/ for a key
# (free tier is sufficient for local development). Required ONLY when running
# the web_search research mechanism; other mechanisms (llm_prior, rag_document,
# multi_llm_consensus, expert_panel, ensemble_forecast, empirical_observation)
# do not read this. Never commit a real key.
TAVILY_API_KEY=
