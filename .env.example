# finESS Environment Configuration
# Copy this file to set up your local environment:
#
#   cp .env.example .env          # For Prisma (database)
#   cp .env.example .env.local    # For Next.js (runtime API keys)
#
# WHY TWO FILES?
#   - Prisma CLI reads DATABASE_URL from .env at generate/push time
#   - Next.js reads OPENROUTER_API_KEY from .env.local at runtime
#   - Both files are gitignored — your secrets stay local
#   - Do not leave DATABASE_URL empty in .env.local; it can override .env
#     and break Save/Load + Calibration routes.

# === Database (required — used by Prisma) ===
# SQLite for local development (file-based, no server needed)
DATABASE_URL=file:./dev.db

# === AI API Key (required for AI-generated graphs) ===
# Get your key at: https://openrouter.ai/keys
# The PE demo works without this key — only needed for custom queries
OPENROUTER_API_KEY=

# === AI Models (used by the in-app selector) ===
# Comma-separated: model-id|Label,model-id|Label
# JSON array is also supported: [{"id":"provider/model","label":"Model label"}]
OPENROUTER_MODELS=
OPENROUTER_DEFAULT_MODEL=
