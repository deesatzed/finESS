# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# local reference prototypes kept out of the app root status
/distribclin_demo.html
/distribclin_expert_system_demo2.html
/hometier-app.html
/hometier-app2.html

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma
/lib/generated/prisma
*.db

# claude-code session exports (may contain secrets, transcripts, working state)
/*-command-message*.txt
/*-export.txt
/transcript-*.txt

# claude-code worktrees and runtime state
/.claude/

# Python sidecar
services/**/.venv/
services/**/__pycache__/
services/**/*.pyc
services/**/.pytest_cache/

# Cache directory created at runtime by ace_hospital's WeatherLoader
# (default weather_config['cache_dir']). Real weather data fetched on
# demand; should not be checked in.
/data/weather/
