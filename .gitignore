# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# local reference prototypes kept out of the app root status
/distribclin_demo.html
/distribclin_expert_system_demo2.html
/hometier-app.html
/hometier-app2.html

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma
/lib/generated/prisma
*.db

# claude-code session exports (may contain secrets, transcripts, working state)
/*-command-message*.txt
/*-export.txt
/transcript-*.txt

# claude-code worktrees and runtime state
/.claude/

# Python sidecar
services/**/.venv/
services/**/__pycache__/
services/**/*.pyc
services/**/.pytest_cache/

# Cache directory created at runtime by ace_hospital's WeatherLoader
# (default weather_config['cache_dir']). Real weather data fetched on
# demand; should not be checked in.
/data/weather/

# B3 RAG local vector store. LanceDB writes per-workspace Arrow/Lance
# files under data/lancedb/<workspaceId>. These contain user-uploaded
# document embeddings and chunk text; they are local-only and never
# checked in. The directory is recreated on first upload.
/data/lancedb/

# B3 RAG document uploads (raw bytes kept temporarily during chunking).
# Documents themselves are not persisted as files — only the SemanticDocument
# row (metadata) and the LanceDB chunks survive past the request. This
# directory is for transient buffering only.
/data/documents/

# B3 transformers.js model cache. The BAAI/bge-small-en-v1.5 model
# downloads on first embedding call (~130 MB) and is cached locally
# under data/.cache/transformers — local-only, never committed.
/data/.cache/
