generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Analysis {
  id              String   @id @default(cuid())
  userId          String?
  workspaceId     String?
  query           String
  graphJson       String
  resultJson      String?
  sensitivityJson String?
  seed            Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user                User?                @relation(fields: [userId], references: [id])
  workspace           Workspace?           @relation(fields: [workspaceId], references: [id])
  calibrationOutcomes CalibrationOutcome[]

  @@index([userId])
  @@index([workspaceId, createdAt])
}

/// CalibrationOutcome attaches an observed outcome to EITHER an Analysis
/// (Path A / Path B saved analysis) OR a Forecast (Path B Forecast Mode,
/// R6-05).
///
/// `analysisId` is now nullable so Forecast-Mode results — which are NOT
/// persisted as Analysis rows because they are produced by the Python
/// ensemble sidecar and have a completely different shape — can carry
/// calibration outcomes too.
///
/// `forecastId` is a client-generated opaque string returned by
/// POST /api/forecast. There is intentionally NO `Forecast` model: until
/// forecasts are durably saved we treat the id as a free-form correlation
/// key only.
///
/// The API handler enforces "exactly one of analysisId / forecastId" via
/// `validateCalibrationOutcomeRequest`. R6-06 will wire forecastId-keyed
/// outcomes back into the ensemble sidecar's /outcome endpoint.
model CalibrationOutcome {
  id                   String   @id @default(cuid())
  userId               String?
  workspaceId          String?
  analysisId           String?
  forecastId           String?
  predictedProbability Float
  actualOutcome        Boolean
  recordedAt           DateTime @default(now())

  user      User?      @relation(fields: [userId], references: [id])
  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  analysis  Analysis?  @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workspaceId, recordedAt])
  @@index([analysisId, workspaceId])
  @@index([forecastId, workspaceId])
}

model User {
  id           String   @id @default(cuid())
  localSubject String   @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspaces          Workspace[]
  sessions            LocalSession[]
  analyses            Analysis[]
  calibrationOutcomes CalibrationOutcome[]
}

model Workspace {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions            LocalSession[]
  analyses            Analysis[]
  calibrationOutcomes CalibrationOutcome[]

  @@index([userId])
}

model LocalSession {
  id          String   @id @default(cuid())
  tokenHash   String   @unique
  userId      String
  workspaceId String
  createdAt   DateTime @default(now())
  expiresAt   DateTime

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workspaceId])
}

model AuditEvent {
  id           String   @id @default(cuid())
  userId       String?
  workspaceId  String?
  sessionId    String?
  eventType    String
  subjectType  String?
  subjectId    String?
  metadataJson String?
  createdAt    DateTime @default(now())

  @@index([userId, workspaceId, createdAt])
  @@index([eventType, createdAt])
  @@index([subjectType, subjectId])
}
