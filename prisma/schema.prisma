generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Analysis {
  id              String   @id @default(cuid())
  userId          String?
  workspaceId     String?
  query           String
  graphJson       String
  resultJson      String?
  sensitivityJson String?
  seed            Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user                User?                @relation(fields: [userId], references: [id])
  workspace           Workspace?           @relation(fields: [workspaceId], references: [id])
  calibrationOutcomes CalibrationOutcome[]

  @@index([userId])
  @@index([workspaceId, createdAt])
}

/// CalibrationOutcome attaches an observed outcome to EITHER an Analysis
/// (Path A / Path B saved analysis) OR a Forecast (Path B Forecast Mode,
/// R6-05).
///
/// `analysisId` is now nullable so Forecast-Mode results — which are NOT
/// persisted as Analysis rows because they are produced by the Python
/// ensemble sidecar and have a completely different shape — can carry
/// calibration outcomes too.
///
/// `forecastId` is a client-generated opaque string returned by
/// POST /api/forecast. There is intentionally NO `Forecast` model: until
/// forecasts are durably saved we treat the id as a free-form correlation
/// key only.
///
/// The API handler enforces "exactly one of analysisId / forecastId" via
/// `validateCalibrationOutcomeRequest`. R6-06 will wire forecastId-keyed
/// outcomes back into the ensemble sidecar's /outcome endpoint.
model CalibrationOutcome {
  id                   String   @id @default(cuid())
  userId               String?
  workspaceId          String?
  analysisId           String?
  forecastId           String?
  predictedProbability Float
  actualOutcome        Boolean
  recordedAt           DateTime @default(now())

  user      User?      @relation(fields: [userId], references: [id])
  workspace Workspace? @relation(fields: [workspaceId], references: [id])
  analysis  Analysis?  @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workspaceId, recordedAt])
  @@index([analysisId, workspaceId])
  @@index([forecastId, workspaceId])
}

/// SemanticConversation persists the full state-machine snapshot for a
/// Semantic Mode conversation (Phase A2). One row per conversation; the
/// `stateJson` blob is the serialized SemanticState discriminated union
/// (see lib/semantic/persistence.ts).
///
/// Local-only / single-user posture: every row carries both `userId` and
/// `workspaceId`, enforced via NOT NULL columns and the same ownership
/// guards used by Analysis. Cascading deletes on User/Workspace match the
/// LocalSession pattern so wiping an account leaves no orphan rows.
///
/// `stateKind` mirrors `SemanticState["kind"]` and is denormalized for
/// fast filtering ("show me everything still in REVIEWING_RESEARCH").
model SemanticConversation {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  query       String
  stateKind   String
  stateJson   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId, workspaceId, updatedAt])
  @@index([userId, stateKind])
}

/// SemanticDocument is a user-uploaded reference document indexed for the
/// Phase B3 RAG research mechanism. One row per uploaded file.
///
/// Local-only posture: the raw bytes are NEVER persisted — they are
/// chunked + embedded into the workspace's LanceDB table at upload time
/// and discarded. Only the metadata (filename, sha256, mimeType, size,
/// chunkCount) survives, plus the embeddings sitting in
/// `data/lancedb/<workspaceId>` (gitignored).
///
/// Dedup is content-addressed per user: the `(userId, sha256)` uniqueness
/// constraint prevents the same user from re-embedding the same file
/// twice. Different users may upload the same content independently
/// because their workspaces have separate LanceDB tables; the unique
/// constraint is scoped to the user, not global.
///
/// On row delete the corresponding chunks should be evicted from the
/// LanceDB table by the caller (lib/rag/store.ts removeDocument).
/// Prisma cannot cascade into LanceDB, so the API DELETE handler is
/// responsible for sequencing both deletes.
model SemanticDocument {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  filename    String
  mimeType    String
  sha256      String
  sizeBytes   Int
  chunkCount  Int
  createdAt   DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, sha256])
  @@index([userId, workspaceId, createdAt])
}

model User {
  id           String   @id @default(cuid())
  localSubject String   @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspaces            Workspace[]
  sessions              LocalSession[]
  analyses              Analysis[]
  calibrationOutcomes   CalibrationOutcome[]
  semanticConversations SemanticConversation[]
  semanticDocuments     SemanticDocument[]
}

model Workspace {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions              LocalSession[]
  analyses              Analysis[]
  calibrationOutcomes   CalibrationOutcome[]
  semanticConversations SemanticConversation[]
  semanticDocuments     SemanticDocument[]

  @@index([userId])
}

model LocalSession {
  id          String   @id @default(cuid())
  tokenHash   String   @unique
  userId      String
  workspaceId String
  createdAt   DateTime @default(now())
  expiresAt   DateTime

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workspaceId])
}

model AuditEvent {
  id           String   @id @default(cuid())
  userId       String?
  workspaceId  String?
  sessionId    String?
  eventType    String
  subjectType  String?
  subjectId    String?
  metadataJson String?
  createdAt    DateTime @default(now())

  @@index([userId, workspaceId, createdAt])
  @@index([eventType, createdAt])
  @@index([subjectType, subjectId])
}
